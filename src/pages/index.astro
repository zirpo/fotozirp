---
import { getCollection } from 'astro:content';

// Fetch all the AI-generated markdown files
const allPosts = await getCollection('posts');

// Sort them by date (newest first)
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zirpography - Portfolio</title>
    <style>
        body { 
            font-family: system-ui, -apple-system, sans-serif; 
            background: #111; /* Dark mode background */
            color: #eee; 
            margin: 0; 
            padding: 2rem; 
        }
        main { max-width: 900px; margin: 0 auto; }
        h1 { text-align: center; margin-bottom: 4rem; font-weight: 300; letter-spacing: 2px; }
        
        .post { margin-bottom: 6rem; text-align: center; }
        .post img { 
            max-width: 100%; 
            height: auto; 
            border-radius: 4px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .post h2 { margin: 1.5rem 0 0.5rem; font-weight: 400; font-size: 1.5rem; }
        
        .metadata { 
            color: #888; 
            font-size: 0.9rem; 
            display: flex; 
            justify-content: center; 
            gap: 1.5rem; 
            flex-wrap: wrap; 
        }
    </style>
</head>
<body>
    <main>
        <h1>ZIRPOGRAPHY</h1>
        
        {sortedPosts.map(post => (
            <article class="post">
                <img src={post.data.image} alt={post.data.title} loading="lazy" />
                <h2>{post.data.title}</h2>
                <div class="metadata">
                    <span>📷 {post.data.camera}</span>
                    <span>🔭 {post.data.lens}</span>
                    <span>⚙️ {post.data.aperture} | {post.data.shutter} | ISO {post.data.iso}</span>
                </div>
            </article>
        ))}
    </main>
</body>
</html>
